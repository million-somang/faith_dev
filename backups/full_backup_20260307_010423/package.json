{
  "name": "faithlink-platform",
  "private": true,
  "packageManager": "npm@10.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down"
  },
  "devDependencies": {
    "puppeteer": "^24.37.5",
    "turbo": "^2.4.2",
    "typescript": "^5.0.0"
  }
}
