{
  "name": "faithlink-platform",
  "private": true,
  "packageManager": "npm@10.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
    "scripts": {
      "build": "turbo run build",
      "start:prod": "tsx apps/api-server/src/server.ts",
      "dev": "turbo run dev --concurrency 25",
      "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down"
  },
  "devDependencies": {
    "puppeteer": "^24.37.5",
    "turbo": "^2.4.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "node-cron": "^4.2.1"
  }
}
